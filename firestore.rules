rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Kullanıcı Profilleri ──────────────────────────────────────────────────
    // Yalnızca kendi belgesini okuyabilir/yazabilir; başkasının profiline erişemez.
    match /users/{userId} {

      // Okuma: sadece kendi profili
      allow read: if request.auth != null && request.auth.uid == userId;

      // Yazma: sadece kendi profili; izin verilen alanlar dışında veri yazılamaz
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && isValidUserDoc(request.resource.data);
    }
  }

  // ─── Yardımcı Fonksiyonlar ──────────────────────────────────────────────────

  // Kullanıcı belgesi yalnızca bu alanları içerebilir
  function isValidUserDoc(data) {
    return data.keys().hasOnly([
      'uid', 'displayName', 'email', 'photoUrl',
      'lastSeen', 'fcmToken', 'prayerStreak'
    ]);
  }
}
